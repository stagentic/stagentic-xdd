{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-7",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5-20251001"
  },
  "permissions": {
    "allow": [
      "Bash(git commit*)",
      "Bash(git add*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(gh repo view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr checks*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh release list*)",
      "Bash(gh release view*)",
      "Bash(python3 -m pytest --collect-only -q)",
      "Bash(python3 -m pytest --collect-only -q *)",
      "Bash(pytest --collect-only -q)",
      "Bash(uv run pytest*)"
    ],
    "deny": [
      "Bash(git push*)"
    ]
  },
  "enabledPlugins": {
    "stagentic-promptbook@stagentic": true
  }
}
