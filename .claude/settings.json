{
  "permissions": {
    "allow": [
      "Bash(git commit*)",
      "Bash(git add*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(gh repo view*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr checks*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh release list*)",
      "Bash(gh release view*)",
      "Bash(python3 -m pytest --collect-only -q)",
      "Bash(python3 -m pytest --collect-only -q *)",
      "Bash(pytest --collect-only -q)",
      "Bash(uv run pytest*)"
    ],
    "deny": [
      "Bash(git push*)"
    ]
  },
  "enabledPlugins": {
    "stagentic-promptbook@stagentic": true
  }
}
